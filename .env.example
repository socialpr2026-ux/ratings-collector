PORT=8787
APP_ORIGIN=http://localhost:5173
DATA_DIR=./data
APIFY_TOKEN=
APIFY_MONTHLY_BUDGET_USD=4.50
# Платные резервные Actor выключены по умолчанию. Включайте осознанно: true.
APIFY_FALLBACK_ENABLED=false
# Единый открытый режим без Google OAuth и без отдельных ролей сотрудников.
RATINGS_ALLOW_UNAUTHENTICATED=true
# Рекомендуемый server-to-server publisher без Google API key.
# Оставьте пустым, чтобы использовать резервную публикацию через Sandbox Chromium.
SHEETS_APPS_SCRIPT_URL=
# Технический Agent -> Cloud Function секрет. Он не ограничивает доступ сотрудников.
# Production: случайная строка длиной не менее 32 символов, одинаковая для обоих runtime.
INTERNAL_AGENT_TOKEN=
