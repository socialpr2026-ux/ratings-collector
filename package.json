{
  "name": "ratings-collector",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "engines": {
    "node": ">=20.18 <21"
  },
  "scripts": {
    "dev": "tsx src/server/local.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "start": "node dist-server/src/server/local.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@edgeone/pages-blob": "^0.0.14",
    "@fastify/static": "^9.1.1",
    "cheerio": "^1.2.0",
    "chromium-bidi": "0.7.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.10.0",
    "playwright-core": "1.51.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
